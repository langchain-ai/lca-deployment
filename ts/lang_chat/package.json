{
  "name": "lang-chat",
  "private": true,
  "description": "LangChat Tutor Agent — TypeScript",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "pnpx @langchain/langgraph-cli dev",
    "ui": "tsx ui/server.ts",
    "lint": "eslint agent/**/*.ts ui/**/*.ts",
    "format": "prettier --write agent/**/*.ts ui/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "deepagents": "latest",
    "@langchain/core": "^1.0.0",
    "langchain": "^1.0.0",
    "@langchain/langgraph": "^1.0.0",
    "@langchain/langgraph-sdk": "^1.0.0",
    "@langchain/mcp-adapters": "latest",
    "langsmith": "^0.1.99",

    "express": "^4.18.0",
    "dotenv": "^16.0.0",

    "@langchain/google-genai": "^1.0.0",
    "@langchain/openai": "^1.0.0",
    "@langchain/anthropic": "^1.0.0",
    "@langchain/ollama": "latest"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
