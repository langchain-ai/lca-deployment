# Model provider — set the one your agent uses
ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OPENAI_API_KEY=

# LangSmith tracing (optional)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true

# Supabase — used by auth.py for JWT validation and by ui/app.py for login
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-publishable-key
