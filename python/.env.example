# LangSmith — tracing and deployment
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=lca-deployment

# Alias used by the deep_tutor deployment to call its own API.
# LangSmith reserves LANGSMITH_API_KEY (the CLI strips it on deploy), so we
# forward the same value under a non-reserved name. Leave the line as-is.
DEEP_TUTOR_API_KEY=${LANGSMITH_API_KEY}

# Model provider API keys — set the one you're using
ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key
# GOOGLE_API_KEY=your-google-api-key
