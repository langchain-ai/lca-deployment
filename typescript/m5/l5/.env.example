# Model provider — set the one your agent uses
ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OPENAI_API_KEY=

# LangSmith tracing (optional)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true

# Supabase — used by auth.ts for JWT validation and by ui/app.ts for login
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
